# ─── Server ─────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/converter-hub

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# ─── File Handling ────────────────────────────────
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
FILE_EXPIRY_HOURS=2

# ─── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=debug
