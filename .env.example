# ─────────────────────────────────────────────
#  Converter Hub — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES=30d

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:4200,https://converter-hub-eight.vercel.app

# Resend Email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Converter Hub <noreply@yourdomain.com>

# Redis (optional — disables queue if not set)
REDIS_URL=redis://localhost:6379

# AWS S3 (optional — uses local storage if not set)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Keep-alive self-ping (set to your deployed backend URL)
SELF_PING_URL=https://your-backend.onrender.com/ping
